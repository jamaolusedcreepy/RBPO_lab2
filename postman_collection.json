    {
      "name": "Tickets",
      "item": [
        {
          "name": "Создать тикет",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/tickets", "host": ["{{baseUrl}}"], "path": ["api", "tickets"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Email service is down\",\n  \"description\": \"Corporate email stopped working for all users.\",\n  \"user\": { \"id\": 1 },\n  \"category\": { \"id\": 1 }\n}"
            }
          }
        },
        {
          "name": "Получить все тикеты",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/tickets", "host": ["{{baseUrl}}"], "path": ["api", "tickets"] }
          }
        },
        {
          "name": "Получить тикет по ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/tickets/1", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "1"] }
          }
        },
        {
          "name": "Получить тикеты пользователя",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/tickets/user/1", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "user", "1"] }
          }
        },
        {
          "name": "Получить тикеты агента",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/tickets/agent/1", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "agent", "1"] }
          }
        },
        {
          "name": "Получить просроченные тикеты",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/tickets/overdue", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "overdue"] }
          }
        },
        {
          "name": "Обновить тикет",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/tickets/1", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Server is down — URGENT\",\n  \"description\": \"Production server is not responding. All services affected.\",\n  \"category\": { \"id\": 1 }\n}"
            }
          }
        },
        {
          "name": "Назначить агента на тикет",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/tickets/4/assign?agentId=2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets", "4", "assign"],
              "query": [{ "key": "agentId", "value": "2" }]
            }
          }
        },
        {
          "name": "Изменить статус тикета (OPEN → IN_PROGRESS)",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/tickets/4/status?newStatus=IN_PROGRESS",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets", "4", "status"],
              "query": [{ "key": "newStatus", "value": "IN_PROGRESS" }]
            }
          }
        },
        {
          "name": "Изменить статус тикета (IN_PROGRESS → RESOLVED)",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/tickets/1/status?newStatus=RESOLVED",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets", "1", "status"],
              "query": [{ "key": "newStatus", "value": "RESOLVED" }]
            }
          }
        },
        {
          "name": "Закрыть тикет с решением",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/tickets/5/close?solution=Certificate renewed via Let's Encrypt. HTTPS restored.",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets", "5", "close"],
              "query": [{ "key": "solution", "value": "Certificate renewed via Let's Encrypt. HTTPS restored." }]
            }
          }
        },
        {
          "name": "Удалить тикет",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/tickets/9", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "9"] }
          }
        }
      ]
    },
    {
      "name": "Бизнес-операции",
      "item": [
        {
          "name": "1. Авто-назначение тикета на наименее загруженного агента",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/tickets/4/auto-assign",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets", "4", "auto-assign"]
            },
            "description": "Система находит активного агента с наименьшим числом открытых тикетов и назначает его. Если тикет в статусе OPEN — переводит в IN_PROGRESS.\n\nЗатрагивает: Ticket + Agent. Транзакция."
          }
        },
        {
          "name": "2. Эскалация тикета (смена категории + пересчёт SLA)",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/tickets/4/escalate?categoryId=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets", "4", "escalate"],
              "query": [{ "key": "categoryId", "value": "1" }]
            },
            "description": "Меняет категорию тикета и автоматически пересчитывает дедлайны ответа и решения по SLA новой категории.\n\nЗатрагивает: Ticket + Category + SLA. Транзакция."
          }
        },
        {
          "name": "3. Деактивация агента с переназначением тикетов",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/agents/3/deactivate?reassignToAgentId=2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "agents", "3", "deactivate"],
              "query": [{ "key": "reassignToAgentId", "value": "2" }]
            },
            "description": "Деактивирует агента (id=3) и переназначает все его активные тикеты (OPEN/IN_PROGRESS/ON_HOLD/REOPENED) на другого агента (id=2).\n\nЗатрагивает: Agent + Ticket. Транзакция."
          }
        },
        {
          "name": "4. Статистика по категориям (тикеты + SLA)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/reports/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reports", "categories"]
            },
            "description": "Возвращает по каждой категории: название, параметры SLA (часы ответа/решения), общее число тикетов и разбивку по статусам.\n\nЗатрагивает: Category + Ticket + SLA."
          }
        },
        {
          "name": "4b. Нагрузка на агентов (отчёт)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/reports/agents",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reports", "agents"]
            },
            "description": "Возвращает по каждому агенту: число активных, решённых и закрытых тикетов.\n\nЗатрагивает: Agent + Ticket."
          }
        },
        {
          "name": "5. Повторное открытие закрытого/отменённого тикета",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/tickets/8/reopen?assignToAgentId=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets", "8", "reopen"],
              "query": [{ "key": "assignToAgentId", "value": "1", "description": "Необязательный параметр" }]
            },
            "description": "Переводит тикет из статуса CLOSED или CANCELLED обратно в REOPENED. Пересчитывает SLA-дедлайны от текущего момента. Опционально назначает агента.\n\nЗатрагивает: Ticket + Category + SLA + Agent. Транзакция."
          }
        }
      ]
    },
    {
      "name": "Полный сценарий",
      "item": [
        {
          "name": "Шаг 1 — Создать тикет",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/tickets", "host": ["{{baseUrl}}"], "path": ["api", "tickets"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"VPN не подключается\",\n  \"description\": \"Сотрудники не могут подключиться к корпоративному VPN после обновления.\",\n  \"user\": { \"id\": 2 },\n  \"category\": { \"id\": 3 }\n}"
            },
            "description": "Создаём новый тикет. Запомните id из ответа и замените в следующих шагах."
          }
        },
        {
          "name": "Шаг 2 — Авто-назначить на агента",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/tickets/9/auto-assign",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets", "9", "auto-assign"]
            },
            "description": "Замените 9 на id тикета из шага 1."
          }
        },
        {
          "name": "Шаг 3 — Эскалировать в категорию Infrastructure",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/tickets/9/escalate?categoryId=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets", "9", "escalate"],
              "query": [{ "key": "categoryId", "value": "1" }]
            },
            "description": "Меняем категорию на Infrastructure (Critical SLA). Дедлайны пересчитываются автоматически."
          }
        },
        {
          "name": "Шаг 4 — Перевести в RESOLVED",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/tickets/9/status?newStatus=RESOLVED",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets", "9", "status"],
              "query": [{ "key": "newStatus", "value": "RESOLVED" }]
            }
          }
        },
        {
          "name": "Шаг 5 — Закрыть с описанием решения",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/tickets/9/close?solution=Обновлён VPN-клиент до версии 5.2. Подключение восстановлено.",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets", "9", "close"],
              "query": [{ "key": "solution", "value": "Обновлён VPN-клиент до версии 5.2. Подключение восстановлено." }]
            }
          }
        },
        {
          "name": "Шаг 6 — Повторно открыть тикет",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/tickets/9/reopen",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets", "9", "reopen"]
            },
            "description": "Проблема вернулась — открываем снова. SLA-дедлайны пересчитываются от текущего времени."
          }
        },
        {
          "name": "Шаг 7 — Проверить статистику по категориям",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/reports/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reports", "categories"]
            },
            "description": "Видим итоговое распределение тикетов по категориям и статусам."
          }
        }
      ]
    }
  ]
}
