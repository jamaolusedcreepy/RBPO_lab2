              "raw": "{\n  \"title\": \"VPN не подключается\",\n  \"description\": \"Сотрудники не могут подключиться к корпоративному VPN после обновления.\",\n  \"user\": { \"id\": 2 },\n  \"category\": { \"id\": 3 }\n}"
            },
            "description": "Запомните id из ответа и замените в шагах 3–7."
          }
        },
