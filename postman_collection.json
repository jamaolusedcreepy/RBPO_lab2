          "name": "Шаг 4 — Повторить refresh со старым токеном → 401",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Старый refresh отклонён: 401', () => pm.response.to.have.status(401));",
                  "pm.test('Ошибка содержит REVOKED', () => {",
                  "    pm.expect(pm.response.text()).to.include('REVOKED');",
                  "});",
                  "console.log('Шаг 4 пройден: повторное использование старого refresh-токена отклонено');"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "auth", "refresh"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{oldRefreshToken}}\"\n}" },
            "description": "Использует отозванный refresh-токен. Ожидаем 401 с сообщением об отозванной сессии."
          }
        },
        {
          "name": "Шаг 5 — Проверить сессии в БД (SQL)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/tickets", "host": ["{{baseUrl}}"], "path": ["api", "tickets"] },
            "description": "Этот шаг выполняется в БД напрямую, не через API.\n\nSQL для проверки:\n\nSELECT jti, status, created_at, expires_at, last_used_at\nFROM user_sessions\nORDER BY created_at DESC;\n\nОжидаемый результат:\n- 1 запись REVOKED (использованная сессия из шага 3)\n- 1 запись ACTIVE (новая сессия из шага 3)\n\nЗдесь же подтверждаем что новый access-токен всё ещё работает."
          }
        }
