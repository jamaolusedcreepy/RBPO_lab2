{
  "info": {
    "name": "Support Ticket System",
    "description": "Полная коллекция запросов. Аутентификация через JWT (Bearer token). Basic Auth удалён.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",          "value": "http://localhost:8080", "type": "string" },
    { "key": "accessToken",      "value": "", "type": "string", "description": "Заполняется автоматически после /auth/login или /auth/refresh" },
    { "key": "refreshToken",     "value": "", "type": "string", "description": "Заполняется автоматически после /auth/login или /auth/refresh" },
    { "key": "userAccessToken",  "value": "", "type": "string", "description": "Токен для тестов роли USER" },
    { "key": "agentAccessToken", "value": "", "type": "string", "description": "Токен для тестов роли AGENT" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "description": "Регистрация, вход и обновление токенов. Все эндпоинты открытые — не требуют токена.",
      "item": [
        {
          "name": "Зарегистрировать ADMIN",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin123!\",\n  \"role\": \"ROLE_ADMIN\"\n}" }
          }
        },
        {
          "name": "Зарегистрировать AGENT",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"agent1\",\n  \"password\": \"Agent123!\",\n  \"role\": \"ROLE_AGENT\"\n}" }
          }
        },
        {
          "name": "Зарегистрировать USER",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"user1\",\n  \"password\": \"User1234!\",\n  \"role\": \"ROLE_USER\"\n}" }
          }
        },
        {
          "name": "Слабый пароль → 400",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"weakuser\",\n  \"password\": \"simple\"\n}" },
            "description": "Ожидаем 400 Bad Request: пароль слишком слабый."
          }
        },
        {
          "name": "Войти (получить пару токенов)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken',  body.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "    console.log('Tokens saved. Access:', body.accessToken.substring(0,30) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin123!\"\n}" },
            "description": "После выполнения переменные accessToken и refreshToken заполняются автоматически. В БД создаётся запись в user_sessions со статусом ACTIVE."
          }
        },
        {
          "name": "Обновить пару токенов (refresh)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken',  body.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "    console.log('Tokens refreshed. New access:', body.accessToken.substring(0,30) + '...');",
                  "} else {",
                  "    console.log('Refresh failed:', pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "auth", "refresh"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "description": "Старая сессия → REVOKED. Новая → ACTIVE. Токены в переменных обновляются автоматически."
          }
        },
        {
          "name": "Неверный пароль → 401",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"wrongpassword\"\n}" },
            "description": "Ожидаем 401 Unauthorized."
          }
        }
      ]
    },
