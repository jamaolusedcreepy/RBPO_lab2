    {
      "name": "Сценарий: проверка JWT и сессий",
      "description": "Воспроизводит шаги задания: login → доступ → refresh → повторный refresh (должен упасть).",
      "item": [
        {
          "name": "Шаг 1 — Войти, получить пару токенов",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Есть accessToken',  () => pm.expect(body.accessToken).to.be.a('string'));",
                  "pm.test('Есть refreshToken', () => pm.expect(body.refreshToken).to.be.a('string'));",
                  "pm.collectionVariables.set('accessToken',  body.accessToken);",
                  "pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "console.log('Шаг 1 пройден: токены получены');"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin123!\"\n}" }
          }
        },
        {
          "name": "Шаг 2 — Обратиться к защищённому эндпоинту",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Доступ с access-токеном: 200', () => pm.response.to.have.status(200));",
                  "console.log('Шаг 2 пройден: защищённый эндпоинт доступен');"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/tickets", "host": ["{{baseUrl}}"], "path": ["api", "tickets"] },
            "description": "Использует Bearer {{accessToken}} из переменных коллекции."
          }
        },
        {
          "name": "Шаг 3 — Обновить пару токенов (refresh)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Refresh успешен: 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Новый accessToken',  () => pm.expect(body.accessToken).to.be.a('string'));",
                  "pm.test('Новый refreshToken', () => pm.expect(body.refreshToken).to.be.a('string'));",
                  "",
                  "// Сохраняем старый refreshToken для шага 4",
                  "pm.collectionVariables.set('oldRefreshToken', pm.collectionVariables.get('refreshToken'));",
                  "",
                  "// Обновляем токены",
                  "pm.collectionVariables.set('accessToken',  body.accessToken);",
                  "pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "console.log('Шаг 3 пройден: новая пара получена. Старый refresh сохранён в oldRefreshToken');"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "auth", "refresh"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
