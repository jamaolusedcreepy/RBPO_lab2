  ],
  "item": [
    {
      "name": "SLA",
      "item": [
        {
          "name": "Создать SLA",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/slas", "host": ["{{baseUrl}}"], "path": ["api", "slas"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Express\",\n  \"responseTimeHours\": 2,\n  \"resolutionTimeHours\": 8,\n  \"description\": \"Express SLA for VIP clients\"\n}"
            }
          }
        },
        {
          "name": "Получить все SLA",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/slas", "host": ["{{baseUrl}}"], "path": ["api", "slas"] }
          }
        },
        {
          "name": "Получить SLA по ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/slas/1", "host": ["{{baseUrl}}"], "path": ["api", "slas", "1"] }
          }
        },
        {
          "name": "Обновить SLA",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/slas/1", "host": ["{{baseUrl}}"], "path": ["api", "slas", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Critical\",\n  \"responseTimeHours\": 1,\n  \"resolutionTimeHours\": 4,\n  \"description\": \"Critical issues — updated description\"\n}"
            }
          }
        },
        {
          "name": "Удалить SLA",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/slas/5", "host": ["{{baseUrl}}"], "path": ["api", "slas", "5"] }
          }
        }
      ]
    },
