            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "const token = pm.cookies.get('XSRF-TOKEN');",
                    "if (token) {",
                    "    pm.collectionVariables.set('xsrf_token', token);",
                    "    console.log('CSRF token saved:', token);",
                    "}"
                  ]
                }
              }
            ]
          }
        },
        {
          "name": "2. Создать тикет",
