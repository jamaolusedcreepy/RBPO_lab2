{
  "info": {
    "name": "Support Ticket System",
    "description": "Полная коллекция запросов для системы поддержки тикетов. Включает CRUD по всем сущностям и 5 бизнес-операций.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
